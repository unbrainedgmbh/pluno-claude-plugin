{
  "description": "Route direct Claude-in-Chrome page operations through the Pluno delegation bridge.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude-in-chrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-claude-in-chrome.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
