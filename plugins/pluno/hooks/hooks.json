{
  "description": "Always route Claude-in-Chrome tool selection and page operations through Pluno until it reports an availability or billing fallback.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ToolSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-claude-in-chrome.mjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-claude-in-chrome.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__claude-in-chrome__javascript_tool",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-claude-in-chrome.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-claude-in-chrome.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-claude-in-chrome.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
